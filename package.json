{
  "name": "maher-abaza-portfolio",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "check": "npx --yes npm-check-updates",
    "update": "npx --yes npm-check-updates -u && rm -rf ./node_modules && rm pnpm-lock.yaml && pnpm i",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@nuxt/fonts": "0.14.0",
    "@nuxt/icon": "^2.2.1",
    "@nuxt/image": "^2.0.0",
    "@nuxtjs/color-mode": "4.0.0",
    "@pinia/nuxt": "^0.11.3",
    "@tailwindcss/vite": "^4.2.1",
    "@takumi-rs/core": "^0.70.4",
    "nuxt": "^4.3.1",
    "nuxt-og-image": "6.0.0-beta.47",
    "octokit": "^5.0.5",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@iconify-json/fa6-brands": "^1.2.6",
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/solar": "^1.2.5",
    "@iconify-json/uil": "^1.2.3",
    "@takumi-rs/wasm": "^0.70.4",
    "@vueuse/core": "^14.2.1",
    "@vueuse/nuxt": "^14.2.1",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "overrides": {
      "vite": "npm:rolldown-vite@latest"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@tailwindcss/oxide",
      "esbuild",
      "sharp"
    ]
  }
}